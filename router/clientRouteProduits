const express = require("express");
const authClient = require("../authentification/authClient");
const router = express.Router();
const mesProduits = require("../controller/controllerproduits");

// 🔹 Consultation produits (Public)
router.get("/", mesProduits.getProduits);
router.get("/recommandations/:id", mesProduits.getRecommendations);
router.get("/:id", mesProduits.getProduitById);
router.get("/new", mesProduits.getNewProduits);
// 🔹 Commentaires
router.get("/:id/commentaires", mesProduits.getCommentaires); 
router.post("/:id/commentaires", authClient, mesProduits.ajouterCommentaire); 

module.exports = router;
